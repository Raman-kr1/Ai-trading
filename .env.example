# ============================================================
# AI TRADING SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
APP_NAME=AI-Trading-System

# --- Trading Mode ---
# Set to 'paper' for simulated trading, 'live' for real execution
TRADING_MODE=paper

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/ai_trading
MONGO_DB_NAME=ai_trading

# --- Binance API (Crypto) ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true
# Testnet base URL: https://testnet.binance.vision
# Production base URL: https://api.binance.com
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WS_URL=wss://testnet.binance.vision/ws

# --- Zerodha Kite API (Indian Stocks) ---
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token
ZERODHA_BASE_URL=https://api.kite.trade

# --- Claude AI (Anthropic) ---
CLAUDE_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1024

# --- Risk Management ---
MAX_DAILY_LOSS_PERCENT=2
MAX_TRADE_SIZE_PERCENT=5
MIN_RISK_REWARD_RATIO=2
MIN_CONFIDENCE_SCORE=60
MAX_OPEN_POSITIONS=5

# --- Scheduler ---
TRADING_INTERVAL_MS=60000
MARKET_DATA_CACHE_TTL=30

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- Dashboard ---
DASHBOARD_ENABLED=true
DASHBOARD_AUTH_TOKEN=your_dashboard_secret_token
